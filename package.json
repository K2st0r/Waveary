{
  "name": "waveary-monorepo",
  "private": true,
  "workspaces": [
    "waveary-core",
    "waveary-memory"
  ],
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run build --workspaces && npm run check --workspaces",
    "demo": "npm run demo:build && node examples/dist/run-demo.js",
    "demo:provider": "npm run demo:build && node examples/dist/run-openai-demo.js",
    "models:provider": "npm run demo:build && node examples/dist/list-provider-models.js",
    "demo:build": "npm run build --workspaces && tsc -p examples/tsconfig.json",
    "test": "npm run build --workspaces && npm run test --workspace @waveary/memory && npm run test --workspace @waveary/core"
  }
}
